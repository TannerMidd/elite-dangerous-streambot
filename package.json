{
  "name": "elite-streambot",
  "version": "1.0.1",
  "description": "Bridge Elite Dangerous journal data to Streamer.bot alerts with a flexible rules engine",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "tsx --test tests/safe-eval.test.ts tests/template.test.ts tests/session.test.ts tests/engine.test.ts tests/globals.test.ts",
    "package": "node scripts/package.mjs",
    "fake-journal": "tsx tools/fake-journal.ts",
    "gen-sounds": "node tools/gen-sounds.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "express": "^4.19.2",
    "ws": "^8.18.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
